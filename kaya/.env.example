# ─── Telegram Bot (@BotFather'dan al) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
ALLOWED_USER_IDS=your_telegram_user_id

# ─── LLM — Hybrid mode (Claude Code brain + OpenAI fallback) ────────────────
BRAIN_MODE=hybrid
OPENAI_API_KEY=sk-...
BRAIN_DIRECT_MODEL=gpt-4o-mini
BRAIN_DIRECT_BASE_URL=https://api.openai.com/v1

# Lokal LLM kullanmak icin (MLX/Ollama):
# BRAIN_DIRECT_MODEL=mlx-community/Qwen2.5-72B-Instruct-4bit
# BRAIN_DIRECT_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=local

# ─── Instantly.ai (cold email campaign) ──────────────────────────────────────
INSTANTLY_API_KEY=your_instantly_key

# ─── Pipeline (beautiful-websites-kit root) ──────────────────────────────────
PIPELINE_DIR=..

# ─── Outreach limitleri ──────────────────────────────────────────────────────
MAGNET_MAX_DAILY_EMAILS=50
MAGNET_APPROVAL_MODE=true

# ─── Agent ayarlari ─────────────────────────────────────────────────────────
MAX_AGENT_ITERATIONS=10
HEARTBEAT_ENABLED=true
MOCK_MEMORY=false
